# Optional: only needed if you want a server-side fallback key for local dev
# or for self-hosted demos. The app is BYOK (bring your own key) by default —
# the OpenRouter key is collected from the user in-browser on first run and
# stored in their browser's localStorage, never on the server.
#
# Get a key at: https://openrouter.ai/keys

OPENROUTER_API_KEY=

# Optional: widen the allowlist for the server-side OpenRouter fallback key.
# When OPENROUTER_API_KEY is set, requests that DON'T supply their own
# `apiKey` are restricted to the deployment's own origin by default so the
# hosted demo cannot be used as a free OpenRouter proxy from third-party
# sites or scripts. Add comma-separated hosts here if the UI lives on a
# different domain than the API (e.g. ui.example.com, api.example.com).
# Loopback is always permitted. Leave empty to keep same-origin only.

ALLOWED_FALLBACK_ORIGINS=
