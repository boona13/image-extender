# Optional: only needed if you want server-side fallback keys for local dev
# or self-hosted demos. The app is BYOK (bring your own key) by default —
# provider keys are collected from the user in-browser and stored in their
# browser's localStorage, never on the server.
#
# Get a key at: https://openrouter.ai/keys

OPENROUTER_API_KEY=

# Optional per-capability provider overrides. Leave blank to keep OpenRouter.
# Supported protocols:
# - openrouter-chat-completions
# - openai-chat-completions
# - openai-responses
# - openai-images

IMAGE_PROVIDER_PROTOCOL=
IMAGE_PROVIDER_BASE_URL=
IMAGE_PROVIDER_API_KEY=
IMAGE_PROVIDER_MODEL=

TEXT_PROVIDER_PROTOCOL=
TEXT_PROVIDER_BASE_URL=
TEXT_PROVIDER_API_KEY=
TEXT_PROVIDER_MODEL=

VISION_PROVIDER_PROTOCOL=
VISION_PROVIDER_BASE_URL=
VISION_PROVIDER_API_KEY=
VISION_PROVIDER_MODEL=
